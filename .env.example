# ── TG OPS AI — Environment Template ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- PostgreSQL (platform DB) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tgops
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=tg_ops_ai

# --- MySQL TGAP source (READ-ONLY, requires VPN) ---
DB_HOST=10.60.20.8
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=tgapdb
DB_PORT=3306

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- LangSmith observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=TG OPS AI

# --- App ---
APP_ENV=development
JWT_SECRET=change-before-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Email (disabled by default — summaries are in-app only) ---
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
EMAIL_FROM=
EXECUTIVE_TO_EMAILS=

# --- Scheduler: daily at 06:00 UTC ---
NEWSLETTER_CRON_MINUTE=0
NEWSLETTER_CRON_HOUR=6

# --- Limits ---
MYSQL_QUERY_TIMEOUT_SECONDS=45
MYSQL_MAX_ROWS=5000

# --- Toggles ---
DISABLE_SCHEDULER=0
AUTO_CREATE_SCHEMA=1
TGAP_FIXTURE_ONLY=0      # set to 1 for offline/fixture-only mode
SKIP_PLATFORM_DB_PERSIST=0
